# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings → API)
# Use the project URL without a trailing slash.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Prefer the publishable key (sb_publishable_...) or legacy anon JWT.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only — never expose to the browser
# Prefer the secret key (sb_secret_...) or legacy service_role JWT.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Invitation-only auth: comma-separated Super Admin emails
SUPER_ADMIN_EMAILS=owner@yourcompany.com
